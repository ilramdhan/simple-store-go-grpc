# ─── Go binaries & build artifacts ───────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Go coverage output
coverage.out
coverage.html

# Go build cache (for local builds, not needed in repo)
/bin/
/dist/

# ─── Proto generated code ─────────────────────────────────────────────────────
# Generated by `buf generate` / `make proto-generate`
# Committed to the repo for convenience; regenerate with: make proto-generate
# Uncomment the lines below if you prefer NOT to commit generated code:
# /gen/

# ─── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.env
.envrc                    # direnv

# Never commit secrets or credentials
*.pem
*.key
*.cert
*.p12
*.pfx

# ─── IDE & Editor ─────────────────────────────────────────────────────────────
# JetBrains (GoLand, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr
out/

# VS Code
.vscode/
*.code-workspace

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
\#*\#
.\#*

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─── Docker ───────────────────────────────────────────────────────────────────
# Local docker override files (keep docker-compose.yml, ignore local overrides)
docker-compose.override.yml
docker-compose.local.yml

# ─── Database ─────────────────────────────────────────────────────────────────
# Local SQLite databases (dev/test only — production uses PostgreSQL)
*.sqlite
*.sqlite3
*.db

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Buf / Protobuf ───────────────────────────────────────────────────────────
# buf.lock IS committed (pins exact dependency versions for reproducibility)
# Do NOT ignore buf.lock

# Intermediate buf build artifacts
*.bin
proto.bin

# ─── Testing & Benchmarks ─────────────────────────────────────────────────────
# Benchmark output
*.bench

# Fuzzing corpus (large, kept locally)
testdata/fuzz/

# ─── OS generated ─────────────────────────────────────────────────────────────
Desktop.ini
$RECYCLE.BIN/
*.lnk
